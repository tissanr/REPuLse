# Supabase — required for auth (GitHub OAuth sign-in) and community snippets (Phase S2/S3)
# Get these from your Supabase project settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# GitHub OAuth — required for sign-in via GitHub
# Set up at github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Not needed for local audio/pattern/editor development.
# Run: vercel env pull .env.local  to pull current values from Vercel.
