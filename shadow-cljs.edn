{:source-paths ["app/src" "packages/core/src" "packages/lisp/src"]

 :dependencies []

 :dev-http {3000 "app/public"}

 :builds
 {:app
  {:target :browser
   :output-dir "app/public/js"
   :asset-path "/js"
   :modules {:main {:init-fn repulse.app/init}}
   :devtools {:after-load repulse.app/reload}
   ;; Closure advanced mode renames properties in source JS files (parser.js)
   ;; but npm modules (@lezer/lr) are bundled separately and not advanced-compiled,
   ;; so their internal accesses keep the original names.  The externs file below
   ;; prevents Closure from renaming the LRParser.deserialize spec properties
   ;; (nodeNames, tokenData, topRules, …), fixing the blank-page crash on Netlify.
   ;; :language-out :ecmascript-2020 preserves dynamic import() emitted via the
   ;; Function-constructor workaround in app.cljs.
   :compiler-options {:language-out :ecmascript-2020
                      :externs ["app/externs/lezer-lr.js"]}}

  :test
  {:target :node-script
   :output-to "out/test.js"
   :main repulse.test-runner/main}}}

