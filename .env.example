# REPuLse environment variables
# Copy to .env and fill in values (never commit .env)

# Supabase project URL — found in Project Settings > API
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon (public) key — safe to expose to the browser
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service-role key — server-side only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App public URL (used as OAuth redirect; include trailing slash if needed)
# On Vercel this is set automatically as VERCEL_URL
APP_URL=https://your-app.vercel.app
